  "sceneActions": [
    {
      "name": "Simuler la panne (blast radius)",
      "id": "sa-blast-0001",
      "createdAt": 1767225600000,
      "cypher": "CYPHER 25\nMATCH (f:Router) WHERE elementId(f) IN $nodes\nWITH collect(f.hostname) AS failed\nWITH failed\nMATCH (hq:Router {role:'CORE'})-[:LOCATED_IN]->(:City {code:'PAR'})\nWHERE NOT hq.hostname IN failed\nWITH failed, collect(hq) AS hqs\nMATCH (r:Router)-[:LOCATED_IN]->(c:City)\nWHERE NOT r.hostname IN failed\nWITH failed, hqs, c, collect(r) AS cityRouters\nWHERE NONE(r IN cityRouters WHERE EXISTS {\n  MATCH (r)(()-[:CONNECTED_TO]-(mid:Router WHERE NOT mid.hostname IN failed))*(hq)\n  WHERE hq IN hqs\n})\nUNWIND cityRouters AS stranded\nMATCH p = (stranded)-[:LOCATED_IN]->(c)\nRETURN p",
      "isUpdateQuery": null,
      "categories": null,
      "relationshipTypes": null,
      "hasCypherErrors": false
    },
    {
      "name": "Voisinage reseau (CONNECTED_TO)",
      "id": "sa-neigh-0002",
      "createdAt": 1767225600000,
      "cypher": "MATCH p = (n:Router)-[:CONNECTED_TO]-(:Router)\nWHERE elementId(n) IN $nodes\nRETURN p",
      "isUpdateQuery": null,
      "categories": null,
      "relationshipTypes": null,
      "hasCypherErrors": false
    },
    {
      "name": "Interfaces et liens physiques",
      "id": "sa-iface-0003",
      "createdAt": 1767225600000,
      "cypher": "MATCH p = (n:Router)-[:HAS_INTERFACE]->(:Interface)-[:LINK]-(:Interface)<-[:HAS_INTERFACE]-(:Router)\nWHERE elementId(n) IN $nodes\nRETURN p",
      "isUpdateQuery": null,
      "categories": null,
      "relationshipTypes": null,
      "hasCypherErrors": false
    },
    {
      "name": "Sessions BGP (iBGP + eBGP)",
      "id": "sa-bgp-0004",
      "createdAt": 1767225600000,
      "cypher": "MATCH p = (n:Router)-[:BGP_PEER|EBGP_PEER]-()\nWHERE elementId(n) IN $nodes\nRETURN p",
      "isUpdateQuery": null,
      "categories": null,
      "relationshipTypes": null,
      "hasCypherErrors": false
    },
    {
      "name": "Declarer un incident P1 (simulation)",
      "id": "sa-inc-0005",
      "createdAt": 1767225600000,
      "cypher": "MATCH (r:Router) WHERE elementId(r) IN $nodes\nMERGE (i:Incident {id: 'INC-BLOOM-' + r.hostname})\nSET i.severity = 'P1', i.type = 'SIMULATED', i.started_at = datetime()\nMERGE (i)-[:AFFECTS]->(r)\nSET r.status = 'DOWN'\nRETURN i, r",
      "isUpdateQuery": true,
      "categories": null,
      "relationshipTypes": null,
      "hasCypherErrors": false
    },
    {
      "name": "Retablir (statut UP + suppression incidents)",
      "id": "sa-fix-0006",
      "createdAt": 1767225600000,
      "cypher": "MATCH (r:Router) WHERE elementId(r) IN $nodes\nOPTIONAL MATCH (i:Incident)-[:AFFECTS]->(r)\nDETACH DELETE i\nSET r.status = 'UP'\nRETURN r",
      "isUpdateQuery": true,
      "categories": null,
      "relationshipTypes": null,
      "hasCypherErrors": false
    }
  ]
}