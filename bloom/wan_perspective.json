  "templates": [
    {
      "name": "Backbone CORE (demo etape 1)",
      "id": "tmpl:1",
      "createdAt": 1767225600000,
      "text": "backbone core",
      "cypher": "MATCH (a:Router {role:'CORE'})-[r:CONNECTED_TO]-(b:Router {role:'CORE'})\nWHERE a.hostname < b.hostname\nRETURN a, r, b",
      "isUpdateQuery": null,
      "params": [],
      "hasCypherErrors": false
    },
    {
      "name": "Site d'une ville",
      "id": "tmpl:2",
      "createdAt": 1767225600000,
      "text": "site de $ville",
      "cypher": "MATCH p = (c:City)<-[:LOCATED_IN]-(:Router)\nWHERE toLower(c.code) = toLower($ville) OR toLower(c.name) STARTS WITH toLower($ville)\nRETURN p",
      "isUpdateQuery": null,
      "params": [
        {
          "name": "$ville",
          "dataType": "String",
          "collapsed": false,
          "suggestionLabel": "City",
          "suggestionProp": "code",
          "suggestionBoolean": false,
          "cypher": null
        }
      ],
      "hasCypherErrors": false
    },
    {
      "name": "Blast radius d'une panne (demo etape 2)",
      "id": "tmpl:3",
      "createdAt": 1767225600000,
      "text": "blast radius de $routeur",
      "cypher": "CYPHER 25\nWITH [$routeur] AS failed\nWITH failed\nMATCH (hq:Router {role:'CORE'})-[:LOCATED_IN]->(:City {code:'PAR'})\nWHERE NOT hq.hostname IN failed\nWITH failed, collect(hq) AS hqs\nMATCH (r:Router)-[:LOCATED_IN]->(c:City)\nWHERE NOT r.hostname IN failed\nWITH failed, hqs, c, collect(r) AS cityRouters\nWHERE NONE(r IN cityRouters WHERE EXISTS {\n  MATCH (r)(()-[:CONNECTED_TO]-(mid:Router WHERE NOT mid.hostname IN failed))*(hq)\n  WHERE hq IN hqs\n})\nUNWIND cityRouters AS stranded\nMATCH p = (stranded)-[:LOCATED_IN]->(c)\nRETURN p",
      "isUpdateQuery": null,
      "params": [
        {
          "name": "$routeur",
          "dataType": "String",
          "collapsed": false,
          "suggestionLabel": "Router",
          "suggestionProp": "hostname",
          "suggestionBoolean": false,
          "cypher": null
        }
      ],
      "hasCypherErrors": false
    },
    {
      "name": "SPOF - points d'articulation (demo etape 3)",
      "id": "tmpl:4",
      "createdAt": 1767225600000,
      "text": "spof du reseau",
      "cypher": "CALL () {\n  CALL gds.graph.drop('wan_bloom_ap', false) YIELD graphName\n  RETURN count(graphName) AS dropped\n}\nCALL gds.graph.project('wan_bloom_ap', 'Router', {CONNECTED_TO: {orientation: 'UNDIRECTED'}}) YIELD graphName\nCALL gds.articulationPoints.stream(graphName) YIELD nodeId\nRETURN gds.util.asNode(nodeId) AS spof",
      "isUpdateQuery": null,
      "params": [],
      "hasCypherErrors": false
    },
    {
      "name": "Ponts critiques (demo etape 3)",
      "id": "tmpl:5",
      "createdAt": 1767225600000,
      "text": "ponts critiques",
      "cypher": "CALL () {\n  CALL gds.graph.drop('wan_bloom_br', false) YIELD graphName\n  RETURN count(graphName) AS dropped\n}\nCALL gds.graph.project('wan_bloom_br', 'Router', {CONNECTED_TO: {orientation: 'UNDIRECTED'}}) YIELD graphName\nCALL gds.bridges.stream(graphName) YIELD from, to\nWITH gds.util.asNode(from) AS a, gds.util.asNode(to) AS b\nMATCH p = (a)-[:CONNECTED_TO]-(b)\nRETURN p",
      "isUpdateQuery": null,
      "params": [],
      "hasCypherErrors": false
    },
    {
      "name": "Double panne NYC (demo etape 4)",
      "id": "tmpl:6",
      "createdAt": 1767225600000,
      "text": "double panne NYC",
      "cypher": "CYPHER 25\nWITH ['NYC-CORE-01','NYC-CORE-02'] AS failed\nWITH failed\nMATCH (hq:Router {role:'CORE'})-[:LOCATED_IN]->(:City {code:'PAR'})\nWHERE NOT hq.hostname IN failed\nWITH failed, collect(hq) AS hqs\nMATCH (r:Router)-[:LOCATED_IN]->(c:City)\nWHERE NOT r.hostname IN failed\nWITH failed, hqs, c, collect(r) AS cityRouters\nWHERE NONE(r IN cityRouters WHERE EXISTS {\n  MATCH (r)(()-[:CONNECTED_TO]-(mid:Router WHERE NOT mid.hostname IN failed))*(hq)\n  WHERE hq IN hqs\n})\nUNWIND cityRouters AS stranded\nMATCH p = (stranded)-[:LOCATED_IN]->(c)\nRETURN p",
      "isUpdateQuery": null,
      "params": [],
      "hasCypherErrors": false
    },
    {
      "name": "Chemin le plus court entre deux villes (demo etape 5)",
      "id": "tmpl:7",
      "createdAt": 1767225600000,
      "text": "chemin de $de vers $vers",
      "cypher": "CYPHER 25\nMATCH (a:Router)-[:LOCATED_IN]->(ca:City), (b:Router)-[:LOCATED_IN]->(cb:City)\nWHERE toLower(ca.code) = toLower($de) AND toLower(cb.code) = toLower($vers)\nMATCH p = SHORTEST 1 (a)-[:CONNECTED_TO]-+(b)\nRETURN p\nORDER BY reduce(t = 0.0, r IN relationships(p) | t + r.latency_ms) ASC\nLIMIT 1",
      "isUpdateQuery": null,
      "params": [
        {
          "name": "$de",
          "dataType": "String",
          "collapsed": false,
          "suggestionLabel": "City",
          "suggestionProp": "code",
          "suggestionBoolean": false,
          "cypher": null
        },
        {
          "name": "$vers",
          "dataType": "String",
          "collapsed": false,
          "suggestionLabel": "City",
          "suggestionProp": "code",
          "suggestionBoolean": false,
          "cypher": null
        }
      ],
      "hasCypherErrors": false
    },
    {
      "name": "Incidents en cours (demo etape 6)",
      "id": "tmpl:8",
